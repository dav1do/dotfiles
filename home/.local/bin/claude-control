#!/usr/bin/env bash
# claude-control — command & control for Claude Code tmux panes
# Usage:
#   claude-control              — fzf picker with switch/dispatch/spawn/broadcast
#   claude-control summary      — one-line status for tmux bar
#   claude-control send ID MSG  — send prompt to a specific pane
#   claude-control _dispatch ID — (internal, called by fzf execute)
#   claude-control _broadcast   — (internal, called by fzf execute)
#   claude-control _spawn       — (internal, called by fzf execute)
#   claude-control _list        — (internal, raw pane list for fzf reload)

set -euo pipefail

# ---------------------------------------------------------------------------
# Process tree (single snapshot, walked in-memory — no per-pane forks)
# ---------------------------------------------------------------------------

declare -A PROC_ARGS      # pid -> command line
declare -A PROC_CHILDREN  # ppid -> "child child ..."

# Take one ps snapshot of the whole process table. Called once per invocation.
load_proc_table() {
  local pid ppid args
  while read -r pid ppid args; do
    PROC_ARGS[$pid]="$args"
    PROC_CHILDREN[$ppid]+="$pid "
  done < <(ps -axo pid=,ppid=,args= 2>/dev/null)
}

# True if the pid or any descendant runs claude. Iterative DFS over the snapshot.
has_claude_descendant() {
  local stack=("$1") cur child
  while ((${#stack[@]})); do
    cur="${stack[-1]}"
    unset 'stack[-1]'
    [[ "${PROC_ARGS[$cur]:-}" == *claude* ]] && return 0
    for child in ${PROC_CHILDREN[$cur]:-}; do
      stack+=("$child")
    done
  done
  return 1
}

# ---------------------------------------------------------------------------
# Pane discovery
# ---------------------------------------------------------------------------

# Output: pane_id location dir  (pane_id hidden in fzf via --with-nth=2..)
list_claude_panes() {
  load_proc_table
  tmux list-panes -a \
    -F '#{pane_id}|#{session_name}/#{window_name}/#{pane_index}|#{b:pane_current_path}|#{pane_pid}' \
    | while IFS='|' read -r pane_id location dir pid; do
      has_claude_descendant "$pid" || continue
      printf '%s \033[36m%s\033[0m \033[2m%s\033[0m\n' "$pane_id" "$location" "$dir"
    done
}

cmd_summary() {
  local panes count
  panes=$(list_claude_panes 2>/dev/null || true)
  [[ -z "$panes" ]] && { echo ""; return; }
  count=$(grep -c '.' <<<"$panes" || true)
  echo "[C: $count]"
}

# ---------------------------------------------------------------------------
# Direct send (scriptable)
# ---------------------------------------------------------------------------

cmd_send() {
  local pane_id="${1:?Usage: claude-control send <pane_id> <prompt>}"
  shift
  local prompt="${*:?Usage: claude-control send <pane_id> <prompt>}"
  tmux send-keys -t "$pane_id" "$prompt" Enter
}

# ---------------------------------------------------------------------------
# Internal commands (called by fzf execute bindings)
# ---------------------------------------------------------------------------

cmd_dispatch() {
  local pane_id="$1"
  echo ""
  local prompt=""
  # Ctrl-C aborts the read, || true prevents set -e from killing us
  read -r -e -p "  Send to $pane_id > " prompt || true
  if [[ -n "$prompt" ]]; then
    tmux send-keys -t "$pane_id" "$prompt" Enter
    echo "  Sent."
    sleep 0.5
  fi
}

cmd_broadcast() {
  local panes
  panes=$(list_claude_panes 2>/dev/null || true)
  if [[ -z "$panes" ]]; then
    echo "  No panes found."
    read -r -n 1 -p "  Press any key..." || true
    return
  fi

  local count
  count=$(grep -c '.' <<<"$panes" || true)

  echo ""
  echo "  Broadcast to $count pane(s):"
  echo "$panes" | awk '{printf "    %s %s\n", $1, $2}'
  echo ""
  local prompt=""
  read -r -e -p "  Broadcast > " prompt || true
  [[ -z "$prompt" ]] && return

  local confirm=""
  read -r -n 1 -p "  Send to all $count panes? (y/n) " confirm || true
  echo
  [[ "$confirm" != "y" ]] && return

  while IFS= read -r line; do
    local pid
    pid=$(echo "$line" | awk '{print $1}')
    tmux send-keys -t "$pid" "$prompt" Enter
  done <<<"$panes"

  echo "  Broadcast sent."
  sleep 0.5
}

cmd_spawn() {
  echo ""
  local dir=""
  if command -v fd &>/dev/null; then
    dir=$(fd -H -d 3 -t d -E .Trash -E node_modules -E .git -E target . ~ \
      | fzf --prompt '  directory: ' --border-label ' spawn claude ' \
      || true)
  fi

  if [[ -z "${dir:-}" ]]; then
    read -r -e -p "  Directory: " dir || true
  fi

  if [[ -z "$dir" || ! -d "$dir" ]]; then
    echo "  Cancelled."
    sleep 0.3
    return
  fi

  local label
  label=$(basename "$dir")
  local custom_label=""
  read -r -e -p "  Name [$label]: " custom_label || true
  label="${custom_label:-$label}"

  tmux split-window -h -c "$dir" "claude --name '$label'"
}

# ---------------------------------------------------------------------------
# fzf picker
# ---------------------------------------------------------------------------

cmd_picker() {
  local panes
  panes=$(list_claude_panes)

  if [[ -z "$panes" ]]; then
    echo "No Claude Code panes found."
    local answer=""
    read -r -n 1 -p "Spawn a new instance? (y/n) " answer || true
    echo
    [[ "$answer" == "y" ]] && cmd_spawn
    return
  fi

  local self
  self=$(realpath "$0")

  echo "$panes" \
    | fzf --ansi \
      --border-label ' claude control ' \
      --prompt '  ' \
      --header 'enter:switch | ^s:send | ^n:new | ^b:broadcast | ^r:refresh' \
      --with-nth=2.. \
      --no-sort \
      --preview 'tmux capture-pane -e -p -t {1} | tail -$FZF_PREVIEW_LINES' \
      --bind "ctrl-s:execute($self _dispatch {1})" \
      --bind "ctrl-n:execute($self _spawn)+reload($self _list)" \
      --bind "ctrl-b:execute($self _broadcast)" \
      --bind "ctrl-r:reload($self _list)" \
      --bind 'enter:become(tmux switch-client -t {1})'
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

case "${1:-}" in
  summary)    cmd_summary ;;
  send)       shift; cmd_send "$@" ;;
  _dispatch)  shift; cmd_dispatch "$@" ;;
  _broadcast) cmd_broadcast ;;
  _spawn)     cmd_spawn ;;
  _list)      list_claude_panes ;;
  *)          cmd_picker ;;
esac
